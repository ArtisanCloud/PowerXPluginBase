{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerx.dev/schemas/plugin/manifest.json",
  "title": "PowerX Plugin Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "channel",
    "min_core",
    "runtime",
    "frontends",
    "migrations",
    "contracts",
    "rbac",
    "config_schema",
    "lifecycle",
    "signature",
    "build"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^com\\.powerx\\.plugin\\.[a-z0-9\\-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z\\-.]+)?$"
    },
    "channel": {
      "type": "string",
      "enum": ["stable", "beta", "alpha", "dev"]
    },
    "min_core": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "max_core": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "runtime": {
      "type": "object",
      "required": ["backend"],
      "properties": {
        "backend": {
          "type": "object",
          "required": ["entrypoint", "sha256"],
          "properties": {
            "entrypoint": {"type": "string"},
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "env": {
              "type": "object",
              "additionalProperties": {"type": ["string", "number", "boolean"]}
            }
          },
          "additionalProperties": false
        },
        "process": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "frontends": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path", "sha256"],
        "properties": {
          "name": {"type": "string"},
          "path": {"type": "string"},
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "health": {
            "type": "object",
            "properties": {
              "http": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "migrations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "checksum", "reversible"],
        "properties": {
          "id": {"type": "string"},
          "checksum": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "reversible": {"type": "boolean"},
          "notes": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "contracts": {
      "type": "object",
      "required": ["api", "rbac", "config"],
      "properties": {
        "api": {"type": "string"},
        "rbac": {"type": "string"},
        "config": {"type": "string"}
      },
      "additionalProperties": false
    },
    "rbac": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "actions"],
        "properties": {
          "role": {"type": "string"},
          "actions": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      }
    },
    "config_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "secrets": {
      "type": "array",
      "items": {"type": "string"}
    },
    "lifecycle": {
      "type": "object",
      "required": ["status", "effective_date"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "sunset"]
        },
        "effective_date": {
          "type": "string",
          "format": "date"
        },
        "replacement": {"type": "string"},
        "notes": {"type": "string"}
      },
      "additionalProperties": false
    },
    "signature": {
      "type": "object",
      "required": ["hashes", "algorithm", "signed_by"],
      "properties": {
        "hashes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "sha256"],
            "properties": {
              "path": {"type": "string"},
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            },
            "additionalProperties": false
          }
        },
        "algorithm": {"type": "string"},
        "signed_by": {"type": "string"},
        "signed_at": {"type": "string", "format": "date-time"},
        "certificate": {"type": "string"}
      },
      "additionalProperties": false
    },
    "build": {
      "type": "object",
      "required": ["commit", "builder", "timestamp"],
      "properties": {
        "commit": {"type": "string"},
        "builder": {"type": "string"},
        "timestamp": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
