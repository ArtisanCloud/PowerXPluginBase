{
  "$id": "schema/input/base.template.query.v1.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Base Template Query Request",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["todo", "in_progress", "done"],
      "description": "Filter by template status"
    },
    "assignee": {
      "type": "integer",
      "minimum": 1,
      "description": "Filter by assigned user identifier"
    },
    "page": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Pagination page index"
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 20,
      "description": "Pagination page size"
    }
  }
}
